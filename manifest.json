{
  "manifest_version": 3,
  "name": "Page Helper",
  "description": "Developer-configured browser page automation helpers.",
  "version": "0.1.0",
  "permissions": ["alarms", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Page Helper"
  }
}
