{
  "manifest_version": 3,
  "name": "Page Helper Session Keeper",
  "description": "Developer-configured scheduled page clicks for keeping web sessions alive.",
  "version": "0.1.0",
  "permissions": ["alarms", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Page Helper Session Keeper"
  }
}
